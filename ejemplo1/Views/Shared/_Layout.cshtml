<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Los Andes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        /* 1. Fondo minimalista muy claro estilo shadcn */
        body {
            background-color: #f8fafc;
            min-height: 100vh;
            padding-bottom: 2rem;
            color: #0f172a; /* Texto principal oscuro */
        }

        /* 2. Menú de navegación blanco y limpio */
        .navbar-minimalist {
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }

        .card-custom {
            border: 1px solid #e2e8f0;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s, box-shadow 0.2s;
            background: #ffffff;
            color: #0f172a;
        }

            .card-custom:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            }

        /* 3. Footer discreto */
        footer {
            background: transparent;
            color: #64748b;
            text-align: center;
            margin-top: 3rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-minimalist">
            <div class="container">
                <a class="navbar-brand fw-bold text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="titulo andes "></i>Los Andes
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @{
                        var usuarioId = Context.Session.GetString("UsuarioId");
                        var usuarioNombre = Context.Session.GetString("UsuarioNombre");
                    }

                    <ul class="navbar-nav flex-grow-1">
                        @if (!string.IsNullOrEmpty(usuarioId))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="ProductosView" asp-action="Index">
                                    <i class="Productos"></i>Productos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="Tienda" asp-action="Index">
                                    <i class="Tienda"></i>Tienda
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="Reportes" asp-action="Index">
                                    <i class="Reportes"></i>Reportes 
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (!string.IsNullOrEmpty(usuarioId))
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="navbar-text text-dark fw-bold me-3">
                                    <i class="bi bi-person-circle me-1 text-muted"></i>Hola, @usuarioNombre
                                </span>
                            </li>
                            <li class="nav-item ms-lg-3 mt-1 mt-lg-0 d-flex align-items-center">
                                <a class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm fw-bold" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i>Registrarse
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <small>© @DateTime.Now.Year - Distribuidora Los Andes</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
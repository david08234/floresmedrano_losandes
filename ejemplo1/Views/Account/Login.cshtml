@model ejemplo1.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card card-custom border-0 shadow-lg" style="border-radius: 1.5rem;">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center p-3 mb-3 shadow-sm" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill" style="font-size: 2.5rem; color: #667eea;"></i>
                        </div>
                        <h2 class="fw-bold text-dark mb-1">Bienvenido</h2>
                        <p class="text-muted small">Ingresa tus credenciales para continuar</p>
                    </div>

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm small" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small border-0"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold text-secondary small">
                                <i class="bi bi-envelope me-1"></i>Email
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg rounded-3 bg-light border-0 px-3" placeholder="tucorreo@ejemplo.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold text-secondary small">
                                <i class="bi bi-shield-lock me-1"></i>Contraseña
                            </label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg rounded-3 bg-light border-0 px-3" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input shadow-sm" style="cursor: pointer;" />
                            <label asp-for="RememberMe" class="form-check-label text-muted small" style="cursor: pointer;">
                                Recordarme
                            </label>
                        </div>

                        <button type="submit" class="btn w-100 btn-lg rounded-pill fw-bold shadow-sm text-white mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; transition: transform 0.2s;">
                            Ingresar <i class="bi bi-box-arrow-in-right ms-1"></i>
                        </button>
                    </form>

                    <hr class="text-muted opacity-25 mb-4" />

                    <div class="text-center">
                        <span class="text-muted small">¿No tienes cuenta?</span>
                        <a asp-action="Register" class="text-decoration-none fw-bold ms-1" style="color: #764ba2;">Regístrate aquí</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
}
@model List<ejemplo1.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="container mt-4 mb-5">
    <div class="card card-modern border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h2 class="h3 fw-bold">
                <i class="bi bi-cart3 text-primary me-2"></i> Mi Carrito
            </h2>
        </div>
        <div class="card-body p-4">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x fs-1 text-muted"></i>
                    <h4 class="mt-3">Tu carrito está vacío</h4>
                    <a asp-action="Index" class="btn btn-primary rounded-pill mt-3 px-4 shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                        <i class="bi bi-shop me-1"></i> Seguir comprando
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 rounded-start">Producto</th>
                                <th class="text-center border-0">Cantidad</th>
                                <th class="text-end border-0">Precio</th>
                                <th class="text-end border-0">Subtotal</th>
                                <th class="border-0 rounded-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <i class="bi bi-box-seam fs-2 text-secondary"></i>
                                            <div>
                                                <h6 class="mb-0 fw-bold">@item.Producto?.Nombre</h6>
                                                <small class="text-muted">Stock: @item.Producto?.Cantidad</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="input-group input-group-sm" style="width: 120px; margin: 0 auto;">
                                            <button class="btn btn-outline-secondary btn-minus" data-id="@item.Id">-</button>
                                            <input type="number" class="form-control text-center cantidad-input" data-id="@item.Id" value="@item.Cantidad" min="1" max="@item.Producto?.Cantidad" />
                                            <button class="btn btn-outline-secondary btn-plus" data-id="@item.Id">+</button>
                                        </div>
                                    </td>
                                    <td class="text-end text-muted">Bs @item.Producto?.Precio.ToString("N2")</td>
                                    <td class="text-end fw-bold text-primary subtotal" data-id="@item.Id">
                                        Bs @((item.Cantidad * (item.Producto?.Precio ?? 0)).ToString("N2"))
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger btn-remove rounded-circle" data-id="@item.Id" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-top">
                            <tr>
                                <td colspan="3" class="text-end fw-bold fs-5 pt-4">Total:</td>
                                <td class="text-end fw-bold fs-4 pt-4" style="color: #667eea;" id="total">
                                    Bs Bs Bs @ViewBag.Total.ToString("N2")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 shadow-sm border">
                        <i class="bi bi-arrow-left me-1"></i> Seguir comprando
                    </a>
                    <a asp-action="Checkout" class="btn text-white rounded-pill px-4 shadow-sm fw-bold" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                        Proceder al pago <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1.2rem;">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pb-4">
                <i class="bi bi-exclamation-circle text-danger mb-3" style="font-size: 4rem;"></i>
                <h4 class="fw-bold text-dark mb-2">¿Eliminar producto?</h4>
                <p class="text-muted">Este producto será retirado de tu carrito de compras.</p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center gap-2 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger rounded-pill px-4 fw-semibold" id="btnConfirmarEliminar">Sí, eliminar</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function actualizarCarrito() {
        location.reload();
    }

    $(document).ready(function() {

        // Variable para guardar temporalmente qué producto queremos borrar
        var productoAEliminarId = null;
        // Inicializamos el Modal de Bootstrap
        var modalConfirmacion = new bootstrap.Modal(document.getElementById('modalEliminar'));

        function actualizarItem(itemId, nuevaCantidad) {
            $.post('/Tienda/ActualizarCantidad', { itemId: itemId, cantidad: nuevaCantidad })
                .done(function(response) {
                    if (response.success) {
                        if (response.itemRemoved) {
                            actualizarCarrito();
                        } else {
                            $(`.subtotal[data-id='${itemId}']`).text('Bs' + response.subtotal.toFixed(2));
                            $('#total').text('Bs' + response.total.toFixed(2));
                        }
                    } else if (response.message) {
                        // Cambiamos el alert() aquí por console.log o podrías usar un Toast a futuro
                        console.log(response.message);
                        actualizarCarrito();
                    }
                });
        }

        $('.btn-plus').click(function() {
            var itemId = $(this).data('id');
            var input = $(`.cantidad-input[data-id='${itemId}']`);
            var nuevaCantidad = parseInt(input.val()) + 1;
            actualizarItem(itemId, nuevaCantidad);
        });

        $('.btn-minus').click(function() {
            var itemId = $(this).data('id');
            var input = $(`.cantidad-input[data-id='${itemId}']`);
            var nuevaCantidad = parseInt(input.val()) - 1;
            actualizarItem(itemId, nuevaCantidad);
        });

        $('.cantidad-input').change(function() {
            var itemId = $(this).data('id');
            var nuevaCantidad = parseInt($(this).val());
            if (nuevaCantidad > 0) {
                actualizarItem(itemId, nuevaCantidad);
            }
        });

        // Cuando se hace clic en el basurero
        $('.btn-remove').click(function() {
            // Guardamos el ID del producto
            productoAEliminarId = $(this).data('id');
            // Mostramos el modal moderno
            modalConfirmacion.show();
        });

        // Cuando se hace clic en "Sí, eliminar" dentro del Modal
        $('#btnConfirmarEliminar').click(function() {
            if (productoAEliminarId) {
                // Ocultamos el modal
                modalConfirmacion.hide();
                // Mandamos a eliminar (cantidad 0)
                actualizarItem(productoAEliminarId, 0);
            }
        });
    });
</script>
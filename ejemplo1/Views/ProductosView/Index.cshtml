@model IEnumerable<ejemplo1.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="container mt-4">
    <div class="card card-custom border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-bottom-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="h3 mb-1 fw-bold">
                        <i class="bi bi-box-seam text-primary me-2"></i>Nuestro Catálogo
                    </h2>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-database"></i> Total: @(Model?.Count() ?? 0) productos disponibles
                    </p>
                </div>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Producto
                </a>
            </div>
        </div>

        <div class="card-body p-4">
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No hay productos</h4>
                    <p class="text-muted">¡Comienza agregando tu primer producto!</p>
                    <a asp-action="Create" class="btn btn-primary mt-2 rounded-pill">
                        <i class="bi bi-plus-circle me-2"></i>Agregar Producto
                    </a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm card-producto" style="border-radius: 1rem; transition: transform 0.2s;">

                                <div class="position-relative text-center p-3 bg-white" style="border-top-left-radius: 1rem; border-top-right-radius: 1rem;">
                                    <img src="@item.ImagenUrl" class="card-img-top"
                                         style="height: 220px; object-fit: contain; background-color: #ffffff;"
                                         alt="Imagen de @item.Nombre" />
                                </div>

                                <div class="card-body d-flex flex-column pt-2">
                                    <h5 class="fw-bold text-dark text-capitalize mb-1 text-truncate" title="@item.Nombre">
                                        @item.Nombre
                                    </h5>

                                    <p class="text-muted small flex-grow-1 mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @(item.Descripcion ?? "Sin descripción disponible.")
                                    </p>

                                    <div class="mb-3">
                                        @if (item.Cantidad == 0)
                                        {
                                            <span class="badge rounded-pill bg-danger-subtle text-danger px-2 py-1 small">
                                                <i class="bi bi-x-circle me-1"></i>Agotado
                                            </span>
                                        }
                                        else if (item.Cantidad < 5)
                                        {
                                            <span class="badge rounded-pill bg-warning-subtle text-warning-depth px-2 py-1 small" style="color: #ea580c; background-color: #ffedd5;">
                                                <i class="bi bi-exclamation-triangle me-1"></i>Pocas unidades (@item.Cantidad)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-success-subtle text-success px-2 py-1 small" style="color: #16a34a; background-color: #dcfce7;">
                                                <i class="bi bi-check-circle me-1"></i>Stock: @item.Cantidad und.
                                            </span>
                                        }
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top border-light">
                                        <span class="fw-extrabold fs-4 text-primary">
                                            Bs Bs Bs @item.Precio.ToString("N2")
                                        </span>

                                        <button class="btn btn-sm rounded-pill px-3 text-white fw-bold shadow-sm d-flex align-items-center gap-1" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                                            <i class="bi bi-cart-plus"></i> Agregar
                                        </button>
                                    </div>
                                </div>

                                <div class="card-footer bg-light border-0 d-flex justify-content-around py-2" style="border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-info small text-decoration-none" title="Ver detalles">
                                        <i class="bi bi-eye"></i> Detalles
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-warning small text-decoration-none" title="Editar">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger small text-decoration-none" title="Eliminar">
                                        <i class="bi bi-trash"></i> Borrar
                                    </a>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Efecto hover interactivo para las tarjetas */
    .card-producto:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.125) !important;
    }
</style>